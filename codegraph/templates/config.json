{
  "version": 1,
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "**/*.py",
    "**/*.go",
    "**/*.rs",
    "**/*.java",
    "**/*.c",
    "**/*.h",
    "**/*.cpp",
    "**/*.hpp",
    "**/*.cc",
    "**/*.cxx",
    "**/*.cs",
    "**/*.php",
    "**/*.rb",
    "**/*.swift",
    "**/*.kt",
    "**/*.kts",
    "**/*.dart",
    "**/*.svelte",
    "**/*.liquid"
  ],
  "exclude": [
    "**/.git/**",
    "**/node_modules/**",
    "**/vendor/**",
    "**/Pods/**",
    "**/dist/**",
    "**/build/**",
    "**/out/**",
    "**/bin/**",
    "**/obj/**",
    "**/target/**",
    "**/*.min.js",
    "**/*.bundle.js",
    "**/.next/**",
    "**/.nuxt/**",
    "**/.svelte-kit/**",
    "**/.output/**",
    "**/.turbo/**",
    "**/.cache/**",
    "**/.parcel-cache/**",
    "**/.vite/**",
    "**/.nx/**",
    "**/.yarn/cache/**",
    "**/.pnpm-store/**",
    "**/__pycache__/**",
    "**/.venv/**",
    "**/venv/**",
    "**/site-packages/**",
    "**/.pytest_cache/**",
    "**/.mypy_cache/**",
    "**/.ruff_cache/**",
    "**/*.egg-info/**",
    "**/go/pkg/mod/**",
    "**/target/debug/**",
    "**/target/release/**",
    "**/.gradle/**",
    "**/.m2/**",
    "**/.dart_tool/**",
    "**/.vs/**",
    "**/.nuget/**",
    "**/coverage/**",
    "**/htmlcov/**",
    "**/.nyc_output/**",
    "**/test-results/**",
    "**/.idea/**",
    "**/logs/**",
    "**/tmp/**",
    "**/temp/**",
    "**/_build/**",
    "**/docs/_build/**",
    "**/infra/**",
    "**/.codegraph/**"
  ],
  "languages": [],
  "frameworks": [],
  "maxFileSize": 1048576,
  "extractDocstrings": true,
  "trackCallSites": true
}
